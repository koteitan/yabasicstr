{
  "name": "yabasicstr",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "description": "yabasic-style BASIC interpreter on the web with built-in nostr signing",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test:build": "tsc -p tsconfig.test.json",
    "test": "npm run test:build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "i18next": "^23.15.1",
    "nostr-tools": "^2.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
